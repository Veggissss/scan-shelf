{
  "name": "scan-shelf",
  "version": "0.2.4",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:start": "npm run build && npm run start",
    "build:pages": "NEXT_PUBLIC_DEPLOY_ENVIRONMENT=pages next build",
    "start": "next start",
    "lint": "next lint",
    "server": "cd server && npm start",
    "setup": "npm i && cd server && npm i",
    "local": "concurrently \"npm run build && npm run start\" \"npm run server\""
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.5",
    "epubjs": "^0.3.93",
    "next": "14.2.33",
    "next-pwa": "^5.6.0",
    "react": "^18",
    "react-dom": "^18",
    "react-reader": "^2.0.15",
    "use-local-storage-state": "^19.5.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^9.2.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.33",
    "msw": "^2.12.2",
    "postcss": "^8",
    "tailwindcss": "^3.4.18",
    "typescript": "^5"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}